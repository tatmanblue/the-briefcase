# Briefcase MCP Server - Environment Configuration
# Copy this file to .env and fill in your values.

# Semicolon-separated list of directories the server will expose to agents.
# All subdirectories are included recursively.
# Example (Windows):  BRIEFCASE_PATHS=C:\Users\you\Documents;D:\projects\notes
# Example (Unix):     BRIEFCASE_PATHS=/home/you/documents;/mnt/shared/notes
BRIEFCASE_PATHS=

# Directory where the file ID registry (registry.json) is stored.
# This data persists across server restarts so agents can keep file IDs.
# Example (Windows):  BRIEFCASE_DATA_PATH=C:\Users\you\.briefcase
# Example (Unix):     BRIEFCASE_DATA_PATH=/home/you/.briefcase
BRIEFCASE_DATA_PATH=

# Optional: directory where agent-created files are stored.
# Defaults to {first BRIEFCASE_PATHS entry}\new if not set.
# Example (Windows):  BRIEFCASE_NEW_PATH=C:\Users\you\Documents\new
# Example (Unix):     BRIEFCASE_NEW_PATH=/home/you/documents/new
BRIEFCASE_NEW_PATH=

# Optional: path to a .gitignore-style file listing patterns to exclude.
# Defaults to {BRIEFCASE_DATA_PATH}/.briefcase-ignore if not set.
# Leave unset to use the default location.
# Example (Windows):  BRIEFCASE_IGNORE_FILE=C:\Users\you\.briefcase\my-ignore
# Example (Unix):     BRIEFCASE_IGNORE_FILE=/home/you/.briefcase/my-ignore
BRIEFCASE_IGNORE_FILE=
